@page
@model LogoutModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Logout";
}

<div class="container py-5 text-center">
    <div class="card shadow-sm p-4 mx-auto" style="max-width: 400px;">
        <div class="card-body">
            <i class="fa-solid fa-right-from-bracket fa-3x text-primary mb-3"></i>
            <h2 class="card-title mb-3">You have been logged out</h2>
            <p class="text-muted mb-3">Thank you for visiting. You will be redirected to the homepage shortly.</p>
            <a class="btn btn-primary" href="/">Return to Home</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            window.location.href = "/";
        }, 3000);
    </script>
}
