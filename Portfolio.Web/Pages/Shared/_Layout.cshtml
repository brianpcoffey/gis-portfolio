@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – Brian Patrick Coffey | GIS Software Engineer</title>
    <meta name="description" content="GIS Software Engineer portfolio showcasing geospatial development, spatial analysis, and web GIS projects." />
    <meta name="keywords" content="GIS, Software Engineer, ArcGIS, Leaflet, Mapbox, Spatial Analysis, Web GIS" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- ArcGIS CSS -->
    <link rel="stylesheet" href="https://js.arcgis.com/4.28/esri/themes/light/main.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
</head>
<body>
    @{
        var isAuthenticated = HttpContextAccessor?.HttpContext?.User?.Identity?.IsAuthenticated ?? false;
        var name = isAuthenticated ? User.FindFirst(ClaimTypes.Name)?.Value : null;
        var picture = isAuthenticated ? User.FindFirst("picture")?.Value : null;
    }

    <header>
        <nav class="navbar navbar-expand-lg" aria-label="Main navigation" id="mainNav">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <i class="fa-solid fa-globe text-accent"></i>
                    <span class="fw-bold">Brian Patrick Coffey</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-lg-3">
                        <li class="nav-item">
                            <a class="nav-link" href="/#skills">Skills</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Projects">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/#about">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/#contact">Contact</a>
                        </li>
                        <li class="nav-item">
                            <button id="themeToggle" class="theme-toggle-btn btn" type="button" aria-label="Toggle dark/light mode">
                                <i id="themeIcon" class="fa-solid fa-moon"></i>
                            </button>
                        </li>
                        @if (isAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="profile-avatar nav-link p-0" href="#" id="profileDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false" aria-label="Profile menu">
                                    <img src="@picture?.Replace("http://", "https://")" alt="Profile" class="profile-img" />
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item" href="/Logout">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-accent btn-sm" href="/Login">
                                    <i class="fa-brands fa-google me-1"></i> Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container text-center py-4">
            <div class="footer-links mb-3">
                <a href="https://mail.google.com/mail/?view=cm&fs=1&to=brian.coffey@email.com" target="_blank" rel="noopener" aria-label="Email via Gmail">
                    <i class="fa-solid fa-envelope"></i>
                </a>
                <a href="https://linkedin.com/in/brianpcoffey" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
                <a href="https://github.com/brianpcoffey" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
            </div>
            <p class="mb-0 small">&copy; @DateTime.Now.Year Brian Patrick Coffey. All rights reserved.</p>
        </div>
    </footer>

    <!-- Forced Google Login Modal -->
    @if (!isAuthenticated)
    {
        <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content text-center p-4 login-card">
                    <h5 class="modal-title mb-3">Sign in to continue</h5>
                    <a class="btn btn-google btn-lg" href="/Login?handler=Google">
                        <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google Logo" class="btn-google-logo" />
                        Sign in with Google
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/navigation.js"></script>
    <script src="~/js/animations.js"></script>

    @RenderSection("Scripts", required: false)

    <script>
        function copyEmail() {
            navigator.clipboard.writeText('brian.coffey@email.com')
                .then(() => alert('Email copied to clipboard!'));
        }
    </script>
</body>
</html>