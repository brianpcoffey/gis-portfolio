@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- ArcGIS CSS -->
    <link rel="stylesheet" href="https://js.arcgis.com/4.28/esri/themes/light/main.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @{
        var isAuthenticated = HttpContextAccessor?.HttpContext?.User?.Identity?.IsAuthenticated ?? false;
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">BPC</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/Projects">Projects</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <!-- Dark/Light Mode Toggle -->
                    <button id="themeToggle" class="theme-toggle-btn btn btn-outline-light btn-sm" type="button" aria-label="Toggle dark/light mode">
                        <i id="themeIcon" class="fa-solid fa-moon"></i>
                    </button>

                    <!-- Authentication/Profile Dropdown -->
                    @{
                        var name = isAuthenticated ? User.FindFirst(ClaimTypes.Name)?.Value : null;
                        var picture = isAuthenticated ? User.FindFirst("picture")?.Value : null;
                    }
                    @if (isAuthenticated)
                    {
                        <div class="dropdown profile-dropdown">
                            <a class="profile-avatar" href="#" id="profileDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false" aria-label="Profile menu">
                                <img src="@picture?.Replace("http://", "https://")" alt="Profile picture" class="profile-img" />
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end profile-menu" aria-labelledby="profileDropdown">
                                <li>
                                    <a class="dropdown-item profile-logout" href="/Logout" aria-label="Logout">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary btn-sm" href="/Login" aria-label="Login with Google">
                            <i class="fa-brands fa-google"></i> Login
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- Forced Google Login Modal -->
    @if (!isAuthenticated)
    {
        <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content text-center p-4 login-card">
                    <h5 class="modal-title mb-3">Sign in to continue</h5>
                    <a class="btn btn-google btn-lg" href="/Login?handler=Google">
                        <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google Logo" class="btn-google-logo" />
                        Sign in with Google
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>