@page
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section id="hero" class="hero-section" role="region" aria-label="Hero">
    <div class="container">
        <div class="hero-content text-center">
            <h1 class="hero-title">Brian Coffey</h1>
            <p class="hero-subtitle">
                Software Engineer
            </p>
            <p class="hero-desc">
                Software engineer specializing in C# and ASP.NET Core web services,
                building secure and scalable applications. Experience developing
                RESTful APIs, enterprise systems, and web GIS solutions that enable
                data-driven decision making.
            </p>
            <div class="hero-cta">
                <a href="#projects" class="btn btn-accent btn-lg me-2">View Projects</a>
                <a href="#contact" class="btn btn-outline-accent btn-lg">Contact</a>
            </div>
        </div>
    </div>
</section>

<!-- Skills (sourced from resume) -->
<section id="skills" class="skills-section py-5" role="region" aria-labelledby="skillsHeading">
    <div class="container">
        <h2 id="skillsHeading" class="section-title text-center mb-5">Technical Skills</h2>
        <div class="row g-4 justify-content-center">
            <!-- GIS (single category) -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="skill-card h-100" aria-hidden="false">
                    <div class="skill-icon" aria-hidden="true"><i class="fa-solid fa-map-location-dot"></i></div>
                    <h3>GIS</h3>
                    <ul class="skill-list" aria-label="GIS Skills">
                        <li><span class="skill-tag">Spatial Analysis</span></li>
                        <li><span class="skill-tag">Geoprocessing</span></li>
                        <li><span class="skill-tag">Geodatabases</span></li>
                    </ul>
                </div>
            </div>

            <!-- Programming (from resume) -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="skill-card h-100">
                    <div class="skill-icon" aria-hidden="true"><i class="fa-solid fa-code"></i></div>
                    <h3>Programming</h3>
                    <ul class="skill-list" aria-label="Programming Languages">
                        <li><span class="skill-tag">C#</span></li>
                        <li><span class="skill-tag">C++</span></li>
                        <li><span class="skill-tag">JavaScript</span></li>
                        <li><span class="skill-tag">SQL</span></li>
                        <li><span class="skill-tag">HTML / CSS</span></li>
                    </ul>
                </div>
            </div>

            <!-- Frameworks & Web GIS (from resume) -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="skill-card h-100">
                    <div class="skill-icon" aria-hidden="true"><i class="fa-solid fa-layer-group"></i></div>
                    <h3>Frameworks & Web GIS</h3>
                    <ul class="skill-list" aria-label="Frameworks and Web GIS">
                        <li><span class="skill-tag">ASP.NET Core</span></li>
                        <li><span class="skill-tag">Entity Framework</span></li>
                        <li><span class="skill-tag">ArcGIS JS API</span></li>
                        <li><span class="skill-tag">RESTful APIs</span></li>
                    </ul>
                </div>
            </div>

            <!-- Tools & Practices -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="skill-card h-100">
                    <div class="skill-icon" aria-hidden="true"><i class="fa-solid fa-toolbox"></i></div>
                    <h3>Tools & Practices</h3>
                    <ul class="skill-list" aria-label="Tools and practices">
                        <li><span class="skill-tag">SQL Server / SSMS</span></li>
                        <li><span class="skill-tag">Azure DevOps</span></li>
                        <li><span class="skill-tag">xUnit</span></li>
                        <li><span class="skill-tag">DevSecOps / Fortify</span></li>
                        <li><span class="skill-tag">Git / Visual Studio</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Projects -->
<section id="projects" class="projects-section py-5" role="region" aria-labelledby="projectsHeading">
    <div class="container">
        <h2 id="projectsHeading" class="section-title text-center mb-5">Featured Projects</h2>

        <div class="row g-4 justify-content-center">
            <div class="col-12 col-sm-6 col-lg-4">
                <article class="project-card h-100" aria-labelledby="project-state-explorer">
                    <div class="project-image" aria-hidden="true">
                        <i class="fa-solid fa-map fa-3x"></i>
                    </div>
                    <div class="project-info">
                        <h3 id="project-state-explorer" class="project-title">US State Explorer</h3>
                        <p class="project-desc">Interactive GIS dashboard for exploring, comparing, and analyzing U.S. state data with ArcGIS JS API and ASP.NET Core backend.</p>
                        <div class="project-stack" aria-hidden="true">
                            <span class="badge-gis">ArcGIS JS</span>
                            <span class="badge-gis">ASP.NET Core</span>
                            <span class="badge-gis">GeoJSON</span>
                        </div>
                        <div class="mt-3">
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/StateExplorer/Index" title="Open demo">Demo</a>
                            <a class="btn btn-accent btn-sm" href="https://github.com/brianpcoffey/gis-portfolio" target="_blank" rel="noopener">GitHub</a>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="homeFinderTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-house fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="homeFinderTitle" class="project-title">Redlands Smart Home Finder</h3>
                        <p class="project-desc flex-grow-1">GIS-powered tool to discover and rank the top 10 homes in Redlands, CA based on weighted preferences and a composite scoring algorithm.</p>
                        <div class="project-stack mb-3"><span>ArcGIS JS</span> <span>ASP.NET Core</span> <span>PostgreSQL</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/HomeFinder/Index">Demo</a>
                            <a class="btn btn-accent btn-sm" href="https://github.com/brianpcoffey/portfolio" target="_blank" rel="noopener">GitHub</a>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="fiberFlowTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-industry fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="fiberFlowTitle" class="project-title">FiberFlow</h3>
                        <p class="project-desc flex-grow-1">Industrial plant operations dashboard for a fiberglass ducting manufacturer. Shipment GIS routing, order management, inventory tracking with transaction audit logs, and a live revenue dashboard.</p>
                        <div class="project-stack mb-3"><span>ASP.NET Core</span> <span>DataTables</span> <span>Esri GIS</span> <span>PostgreSQL</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/FiberFlow/Index">Demo</a>
                            <a class="btn btn-accent btn-sm" href="https://github.com/brianpcoffey/portfolio" target="_blank" rel="noopener">GitHub</a>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="/Projects" class="btn btn-outline-accent">View all projects</a>
        </div>
    </div>
</section>

<!-- About -->
<section id="about" class="about-section py-5" role="region" aria-labelledby="aboutHeading">
    <div class="container">
        <h2 id="aboutHeading" class="section-title text-center mb-4">About</h2>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="about-card">
                    <p>
                        Software Engineer with 2+ years of experience developing
                        ASP.NET Core and C# applications that support enterprise
                        operations and data-driven decision making. Experienced
                        building RESTful APIs, modernizing legacy systems, and
                        designing secure and scalable backend services using
                        SQL Server and Entity Framework.
                    </p>

                    <p>
                        My work includes developing web applications that automate 
                        complex workflows and improve organizational efficiency. 
                        I have led Agile teams through the full software lifecycle including
                        architecture, implementation, testing, and deployment.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact -->
<section id="contact" class="contact-section py-5" role="contentinfo" aria-labelledby="contactHeading">
    <div class="container">
        <h2 id="contactHeading" class="section-title text-center mb-4">Contact</h2>
        <div class="contact-links">
            <a class="contact-link"
               href="https://mail.google.com/mail/?view=cm&fs=1&to=brianpcoffey99@gmail.com"
               target="_blank"
               rel="noopener"
               aria-label="Email via Gmail">
                <i class="fa-solid fa-envelope"></i>
                brianpcoffey99@gmail.com
            </a>

            <a class="contact-link"
               href="https://linkedin.com/in/brianpatrickcoffey"
               target="_blank"
               rel="noopener">
                <i class="fa-brands fa-linkedin"></i>
                linkedin.com/in/brianpatrickcoffey
            </a>

            <a class="contact-link"
               href="https://github.com/brianpcoffey"
               target="_blank"
               rel="noopener">
                <i class="fa-brands fa-github"></i>
                github.com/brianpcoffey
            </a>
        </div>
    </div>
</section>

@@section Scripts {

<script>
    function copyEmailContact() {
        navigator.clipboard.writeText('brianpcoffey99@gmail.com')
            .then(() => alert('Email copied to clipboard!'));
    }


</script>
}