@page
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
}

<section class="py-5">
    <div class="container">
        <h1 class="section-title text-center mb-5">All Projects</h1>

        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100" aria-labelledby="stateExplorerTitle">
                    <div class="project-image" aria-hidden="true"><i class="fa-solid fa-map fa-3x"></i></div>
                    <div class="project-info">
                        <h3 id="stateExplorerTitle" class="project-title">US State Explorer</h3>
                        <p class="project-desc">Explore, compare, and analyze U.S. states with an interactive ArcGIS-powered dashboard and ASP.NET Core backend.</p>
                        <div class="project-stack"><span>ArcGIS JS</span><span>ASP.NET Core</span></div>
                        <div class="mt-3">
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/StateExplorer/Index">Demo</a>
                            <a class="btn btn-accent btn-sm" href="https://github.com/brianpcoffey/gis-portfolio" target="_blank" rel="noopener">GitHub</a>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
