@page
@using Portfolio.Web.Pages.Projects
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
}
<div class="container py-5">
    <h1 class="mb-4">Project Categories</h1>
    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <a href="/Projects/GIS" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Geographic Information Systems</h5>
                        <p class="card-text">Explore GIS mini-projects for spatial analysis and decision-making.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="/Projects/Financial" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Financial Systems</h5>
                        <p class="card-text">Discover financial applications for budgeting and resource management.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="/Projects/Admin" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Administrative Automation</h5>
                        <p class="card-text">See tools for automating administrative tasks and boosting productivity.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
