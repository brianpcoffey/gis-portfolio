@page
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
}

<section class="py-5">
    <div class="container">
        <h1 class="section-title text-center mb-5">All Projects</h1>

        <div class="row g-4">
            <!-- US State Explorer -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="stateExplorerTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-map fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="stateExplorerTitle" class="project-title">US State Explorer</h3>
                        <p class="project-desc flex-grow-1">Explore, compare, and analyze U.S. states with an interactive ArcGIS-powered dashboard and ASP.NET Core backend.</p>
                        <div class="project-stack mb-3"><span>ArcGIS JS</span> <span>ASP.NET Core</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/StateExplorer/Index">Demo</a>
                            <a class="btn btn-accent btn-sm me-2" href="https://github.com/brianpcoffey/gis-portfolio" target="_blank" rel="noopener">GitHub</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/StateExplorer/Details" aria-label="View technical details for US State Explorer" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- Redlands Smart Home Finder -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="homeFinderTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-house fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="homeFinderTitle" class="project-title">Redlands Smart Home Finder</h3>
                        <p class="project-desc flex-grow-1">GIS-powered tool to discover and rank the top 10 homes in Redlands, CA based on weighted preferences and a composite scoring algorithm.</p>
                        <div class="project-stack mb-3"><span>ArcGIS JS</span> <span>ASP.NET Core</span> <span>PostgreSQL</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/HomeFinder/Index">Demo</a>
                            <a class="btn btn-accent btn-sm me-2" href="https://github.com/brianpcoffey/portfolio" target="_blank" rel="noopener">GitHub</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/HomeFinder/Details" aria-label="View technical details for Redlands Smart Home Finder" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- Batch Geocoding -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="batchGeocodingTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-map-location-dot fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="batchGeocodingTitle" class="project-title">Batch Geocoding</h3>
                        <p class="project-desc flex-grow-1">Upload a CSV of addresses and geocode them in bulk via ArcGIS. View match rates, scores, and coordinates in an interactive DataTables results grid with export support.</p>
                        <div class="project-stack mb-3"><span>ArcGIS</span> <span>Geocoding</span> <span>C#</span> <span>.NET</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/BatchGeocoding">Demo</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/BatchGeocoding/Details" aria-label="View technical details for Batch Geocoding" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- Address Standardization -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="addressStandardizationTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-address-card fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="addressStandardizationTitle" class="project-title">Address Standardization &amp; Validation</h3>
                        <p class="project-desc flex-grow-1">Parse freeform addresses into structured components with NLP-style regex extraction, then validate and score them against ArcGIS geocoding with a confidence tier result.</p>
                        <div class="project-stack mb-3"><span>ArcGIS</span> <span>Address Parsing</span> <span>Geocoding</span> <span>C#</span> <span>.NET</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/AddressStandardization">Demo</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/AddressStandardization/Details" aria-label="View technical details for Address Standardization" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- Reverse Geocoding -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="reverseGeocodingTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-map-pin fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="reverseGeocodingTitle" class="project-title">Reverse Geocoding</h3>
                        <p class="project-desc flex-grow-1">Click anywhere on an interactive ArcGIS map to instantly discover the address or place at that location, with a history of recent lookups and manual coordinate entry.</p>
                        <div class="project-stack mb-3"><span>ArcGIS</span> <span>Reverse Geocoding</span> <span>C#</span> <span>.NET</span> <span>Maps</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/ReverseGeocoding">Demo</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/ReverseGeocoding/Details" aria-label="View technical details for Reverse Geocoding" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- FiberFlow -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100 d-flex flex-column" aria-labelledby="fiberFlowTitle">
                    <div class="project-image mb-3 text-center" aria-hidden="true">
                        <i class="fa-solid fa-industry fa-3x"></i>
                    </div>
                    <div class="project-info flex-grow-1 d-flex flex-column">
                        <h3 id="fiberFlowTitle" class="project-title">Plant Operations Dashboard</h3>
                        <p class="project-desc flex-grow-1">Industrial plant operations dashboard for a fiberglass ducting manufacturer. Shipment GIS routing, order management, inventory tracking with transaction audit logs, and a live revenue dashboard.</p>
                        <div class="project-stack mb-3"><span>ASP.NET Core</span> <span>DataTables</span> <span>Esri GIS</span> <span>PostgreSQL</span></div>
                        <div>
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/PlantOperationsDashboard/Index">Demo</a>
                            <a class="btn btn-accent btn-sm me-2" href="https://github.com/brianpcoffey/portfolio" target="_blank" rel="noopener">GitHub</a>
                            <a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/PlantOperationsDashboard/Details" aria-label="View technical details for Plant Operations Dashboard" title="Technical Details"><i class="fa-solid fa-circle-info"></i></a>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>