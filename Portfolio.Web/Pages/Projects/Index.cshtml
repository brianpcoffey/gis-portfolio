@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
}

<section class="py-5">
    <div class="container">
        <h1 class="section-title text-center mb-5">All Projects</h1>

        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4">
                <article class="project-card h-100" aria-labelledby="stateExplorerTitle">
                    <div class="project-image" aria-hidden="true"><i class="fa-solid fa-map fa-3x"></i></div>
                    <div class="project-info">
                        <h3 id="stateExplorerTitle" class="project-title">US State Explorer</h3>
                        <p class="project-desc">Explore, compare, and analyze U.S. states with an interactive ArcGIS-powered dashboard and ASP.NET Core backend.</p>
                        <div class="project-stack"><span>ArcGIS JS</span><span>ASP.NET Core</span></div>
                        <div class="mt-3">
                            <a class="btn btn-outline-accent btn-sm me-2" href="/Projects/StateExplorer/Index">Demo</a>
                            <a class="btn btn-accent btn-sm" href="https://github.com/brianpcoffey/state-explorer" target="_blank" rel="noopener">GitHub</a>
                        </div>
                    </div>
                </article>
            </div>

            <!-- keep existing project cards for Financial and Admin projects -->
            <div class="col-12 col-md-6 col-lg-4">
                <a href="/Projects/Financial" class="text-decoration-none">
                    <div class="project-card h-100">
                        <div class="project-image" aria-hidden="true"><i class="fa-solid fa-chart-line fa-3x"></i></div>
                        <div class="project-info">
                            <h5 class="project-title">Budget Management System</h5>
                            <p class="project-desc">Secure financial application for budgeting, reporting, and resource management.</p>
                            <div class="project-stack"><span>C#</span><span>SQL Server</span></div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <a href="/Projects/Admin" class="text-decoration-none">
                    <div class="project-card h-100">
                        <div class="project-image" aria-hidden="true"><i class="fa-solid fa-robot fa-3x"></i></div>
                        <div class="project-info">
                            <h5 class="project-title">Workflow Automation Tools</h5>
                            <p class="project-desc">Automated workflows to reduce manual workload and improve administrative productivity.</p>
                            <div class="project-stack"><span>Python</span><span>Power Automate</span></div>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>
