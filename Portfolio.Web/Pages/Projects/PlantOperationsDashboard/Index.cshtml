@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Plant Operations Dashboard";
}

<!-- Include shared GIS/theme utilities so theme-surface and badges match other pages -->
<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/plantoperationsdashboard.css" />
<link rel="stylesheet" href="https://js.arcgis.com/4.29/esri/themes/light/main.css" />

<div class="container-fluid py-3 theme-root">
    <!-- Toast Container for User Feedback -->
    <div aria-live="polite" aria-atomic="true"
         class="position-fixed top-0 end-0 p-3"
         style="z-index: 2000; max-width: 350px; width: 100vw;">
        <div id="fiberflowToastContainer" class="toast-container w-100"></div>
    </div>

    <!-- DASHBOARD HEADER -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="theme-surface shadow-sm rounded p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                <div>
                    <h2 class="mb-1"><i class="fa-solid fa-industry me-2"></i>Plant Operations Dashboard</h2>
                    <p class="text-muted theme-text-muted small mb-0">
                        Live operations, shipments, orders, and inventory for plant manufacturing.
                    </p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-success theme-badge" id="badgeActiveShipments">0 Active Shipments</span>
                    <span class="badge bg-primary theme-badge" id="badgeOpenOrders">0 Open Orders</span>
                    <span class="badge bg-danger theme-badge fiberflow-low-stock" id="badgeLowStock">0 Low Stock</span>
                </div>
            </div>
        </div>
    </div>

    <!-- DASHBOARD ROW: ANALYTICS & MAP -->
    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <div class="card shadow-sm theme-card mb-3">
                <div class="card-header theme-card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-chart-line text-accent"></i>
                    <strong>Revenue Analytics</strong>
                </div>
                <div class="card-body theme-body">
                    <div id="fiberflowRevenueChart" class="fiberflow-chart">
                        <div class="fiberflow-spinner spinner-border text-accent" role="status" aria-label="Loading chart..."></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm theme-card mb-3">
                <div class="card-header theme-card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-boxes-stacked text-accent"></i>
                    <strong>Orders Analytics</strong>
                </div>
                <div class="card-body theme-body">
                    <div id="fiberflowOrdersChart" class="fiberflow-chart">
                        <div class="fiberflow-spinner spinner-border text-accent" role="status" aria-label="Loading chart..."></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm theme-card mb-3">
                <div class="card-header theme-card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-warehouse text-accent"></i>
                    <strong>Inventory Analytics</strong>
                </div>
                <div class="card-body theme-body">
                    <div id="fiberflowInventoryChart" class="fiberflow-chart">
                        <div class="fiberflow-spinner spinner-border text-accent" role="status" aria-label="Loading chart..."></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card shadow-sm theme-card mb-3 fiberflow-tabs-card">
                <div class="card-header theme-card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-route text-accent"></i>
                    <strong>Shipment GIS Map</strong>
                </div>
                <div class="card-body theme-body position-relative">
                    <div class="fiberflow-map-wrapper position-relative">
                        <!-- Basemap Switcher Toolbar (matches HomeFinder) -->
                        <div id="fiberflowMapToolbar" class="position-absolute top-0 end-0 m-2 z-3">
                            <select id="fiberflowBasemapSelect" class="form-select form-select-sm basemap-select" aria-label="Select basemap view">
                                <option value="dark-gray-vector">Dark Gray</option>
                                <option value="satellite">Satellite</option>
                                <option value="hybrid">Hybrid</option>
                                <option value="streets-navigation-vector">Streets</option>
                                <option value="topo-vector">Topographic</option>
                                <option value="osm" selected>OpenStreetMap</option>
                            </select>
                        </div>
                        <div style="width: 100%; min-height: 400px; position: relative;">
                            <div id="fiberflowMap" class="fiberflow-map">
                                <div class="fiberflow-spinner spinner-border text-accent" role="status" aria-label="Loading map..."></div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-1">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DATA GRIDS: ORDERS, SHIPMENTS, INVENTORY -->
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card shadow-sm theme-card mb-3">
                <div class="card-header theme-card-header">
                    <ul class="nav nav-tabs card-header-tabs" id="ordersShipmentsTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="orders-tab" data-bs-toggle="tab" data-bs-target="#ordersTabPane" type="button" role="tab" aria-controls="ordersTabPane" aria-selected="true">
                                <i class="fa-solid fa-boxes-stacked text-accent"></i> Orders
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="shipments-tab" data-bs-toggle="tab" data-bs-target="#shipmentsTabPane" type="button" role="tab" aria-controls="shipmentsTabPane" aria-selected="false">
                                <i class="fa-solid fa-truck-fast text-accent"></i> Shipments
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventoryTabPane" type="button" role="tab" aria-controls="inventoryTabPane" aria-selected="false">
                                <i class="fa-solid fa-warehouse text-accent"></i> Inventory
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body theme-body">
                    <div class="tab-content" id="ordersShipmentsTabsContent">
                        <div class="tab-pane fade show active" id="ordersTabPane" role="tabpanel" aria-labelledby="orders-tab">
                            <div class="d-flex justify-content-end mb-2">
                                <button class="btn btn-accent btn-sm theme-btn" id="btnNewOrder"><i class="fa-solid fa-plus me-1"></i>New Order</button>
                            </div>
                            <div class="fiberflow-spinner spinner-border text-accent d-none" id="ordersTableSpinner" role="status" aria-label="Loading orders..."></div>
                            <div class="table-responsive">
                                <table id="fiberflowOrdersTable" class="table table-striped table-hover w-100"></table>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="shipmentsTabPane" role="tabpanel" aria-labelledby="shipments-tab">
                            <div class="d-flex justify-content-end mb-2">
                                <button class="btn btn-accent btn-sm theme-btn" id="btnNewShipment"><i class="fa-solid fa-plus me-1"></i>New Shipment</button>
                            </div>
                            <div class="fiberflow-spinner spinner-border text-accent d-none" id="shipmentsTableSpinner" role="status" aria-label="Loading shipments..."></div>
                            <div class="table-responsive">
                                <table id="fiberflowShipmentsTable" class="table table-striped table-hover w-100"></table>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="inventoryTabPane" role="tabpanel" aria-labelledby="inventory-tab">
                            <div class="d-flex justify-content-end mb-2">
                                <button class="btn btn-accent btn-sm theme-btn" id="btnNewMaterial"><i class="fa-solid fa-plus me-1"></i>New Material</button>
                            </div>
                            <div class="fiberflow-spinner spinner-border text-accent d-none" id="inventoryTableSpinner" role="status" aria-label="Loading inventory..."></div>
                            <div class="table-responsive">
                                <table id="fiberflowInventoryTable" class="table table-striped table-hover w-100"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <!-- Inventory card removed; now in tabs above -->

        <!-- MODALS (Order CRUD, Shipment Status, Inventory Details) -->
        <div id="fiberflowModals"></div>
    </div>

@section Scripts {
    <script src="~/lib/d3/d3.min.js"></script>
    <script src="https://js.arcgis.com/4.29/"></script>
    <script src="~/js/toasts.js"></script>
    <script src="~/js/PlantOperationsDashboard/dashboard.js"></script>
    <script src="~/js/PlantOperationsDashboard/orders.js"></script>
    <script src="~/js/PlantOperationsDashboard/shipments.js"></script>
    <script src="~/js/PlantOperationsDashboard/inventory.js"></script>
}
