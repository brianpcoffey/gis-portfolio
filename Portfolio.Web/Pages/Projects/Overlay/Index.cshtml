@page
@model Portfolio.Web.Pages.Projects.Overlay.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Spatial Overlay / Zone Tagger";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />

<div class="spatial-compute-page theme-root">
	<div class="project-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-shapes me-2"></i>Spatial Overlay / Zone Tagger</h1>
					<p class="text-muted theme-text-muted mb-0">Point-in-polygon spatial join — tag thousands of points with the zone that contains them and roll up per-zone counts into a live choropleth, backed by a native C++ kernel.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-vector-square me-1"></i>C++ Overlay Kernel</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/Overlay/Details" aria-label="View technical details for Spatial Overlay" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="overlayAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-sliders text-accent"></i><strong>Join Controls</strong></div>
					<div class="card-body d-flex flex-column gap-3">
						<div>
							<label for="overlayPointCount" class="form-label small">Number of points</label>
							<input id="overlayPointCount" class="form-control" type="number" min="20" max="4000" step="20" value="600" />
						</div>
						<div>
							<label for="overlayZones" class="form-label small">Zone layout</label>
							<select id="overlayZones" class="form-select">
								<option value="quadrants" selected>Four district quadrants</option>
								<option value="strips">Three vertical strips</option>
								<option value="diamond">Central diamond + corners</option>
							</select>
						</div>
						<button id="overlayRunBtn" class="btn btn-accent"><i class="fa-solid fa-object-group me-1"></i>Run Spatial Join</button>
						<button id="overlayRegenBtn" class="btn btn-outline-accent"><i class="fa-solid fa-arrows-rotate me-1"></i>Regenerate Points</button>
						<div id="overlayZoneTable"></div>
						<pre id="overlaySummary" class="sample-json mt-auto mb-0"></pre>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-map text-accent"></i><strong>Zone Choropleth</strong></div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-md-3"><div class="kpi-card text-center"><div id="overlayKpiPoints" class="kpi-value">0</div><div class="kpi-label">Points</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="overlayKpiZones" class="kpi-value">0</div><div class="kpi-label">Zones</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="overlayKpiUnassigned" class="kpi-value">0</div><div class="kpi-label">Outside</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="overlayKpiNative" class="kpi-value">No</div><div class="kpi-label">Native</div></div></div>
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3">
							<svg id="overlaySvg" role="img" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" class="w-100" style="max-width: 480px; aspect-ratio: 1;" aria-label="Zone choropleth with points"></svg>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/Overlay/app.js" asp-append-version="true"></script>
}
