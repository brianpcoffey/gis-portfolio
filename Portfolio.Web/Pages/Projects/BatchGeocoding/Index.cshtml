@page
@model Portfolio.Web.Pages.Projects.BatchGeocoding.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Batch Geocoding";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/batchgeocoding.css" />

<div class="batch-geocoding-page">

	<!-- PAGE HEADER -->
	<div class="geocoding-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1">
						<i class="fa-solid fa-map-location-dot me-2"></i>Batch Geocoding
					</h1>
					<p class="text-muted mb-0">
						Upload a CSV of addresses and geocode them in bulk via ArcGIS.
					</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6">
						<i class="fa-solid fa-satellite-dish me-1"></i>ArcGIS Geocoding API
					</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn"
					   href="/Projects/BatchGeocoding/Details"
					   aria-label="View technical details for Batch Geocoding"
					   title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- MAIN CONTENT -->
	<div class="container pb-5">

		<!-- Alert area for client-side validation errors -->
		<div id="uploadAlert" class="alert alert-warning alert-dismissible fade d-none mb-3" role="alert">
			<i class="fa-solid fa-triangle-exclamation me-1"></i>
			<span id="uploadAlertMsg"></span>
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>

		<div class="row g-4">

			<!-- LEFT PANEL: UPLOAD CONTROLS -->
			<div class="col-lg-4">
				<div class="card shadow-sm h-100 theme-card">
					<div class="card-header theme-card-header d-flex align-items-center gap-2">
						<i class="fa-solid fa-upload text-accent"></i>
						<strong>Upload CSV</strong>
					</div>
					<div class="card-body d-flex flex-column gap-3">

						<!-- Drag-and-drop zone -->
						<div id="uploadZone" class="upload-zone text-center" role="button" tabindex="0"
							 aria-label="Drag and drop a CSV file here or click to browse">
							<i class="fa-solid fa-file-csv fa-3x mb-2 text-accent"></i>
							<p class="mb-0 fw-semibold">Drag &amp; drop a CSV file here</p>
							<p class="mb-0 text-muted small">or click to browse</p>
						</div>

						<!-- Hidden file input -->
						<input type="file" id="csvFileInput" accept=".csv" class="d-none" aria-label="Select CSV file" />

						<!-- Expected format -->
						<div>
							<p class="mb-1 small fw-semibold text-muted">Expected format:</p>
							<pre class="format-example mb-0">Id,Address,City,State,Zip
1,123 Main St,Los Angeles,CA,90001</pre>
						</div>

						<!-- Sample downloads -->
						<div>
							<p class="mb-1 small fw-semibold text-muted">
								<i class="fa-solid fa-download me-1"></i>Download a sample CSV:
							</p>
							<div class="d-flex flex-column gap-1">
								<a href="~/samples/batch-geocoding/us-landmarks.csv" download class="btn btn-sm btn-outline-secondary text-start">
									<i class="fa-solid fa-monument me-1"></i>US Landmarks <span class="text-muted">(10 rows)</span>
								</a>
								<a href="~/samples/batch-geocoding/tech-campuses.csv" download class="btn btn-sm btn-outline-secondary text-start">
									<i class="fa-solid fa-building me-1"></i>Tech Campuses <span class="text-muted">(10 rows)</span>
								</a>
								<a href="~/samples/batch-geocoding/sports-stadiums.csv" download class="btn btn-sm btn-outline-secondary text-start">
									<i class="fa-solid fa-futbol me-1"></i>Sports Stadiums <span class="text-muted">(10 rows)</span>
								</a>
								<a href="~/samples/batch-geocoding/mixed-results.csv" download class="btn btn-sm btn-outline-secondary text-start">
									<i class="fa-solid fa-circle-half-stroke me-1"></i>Mixed Results <span class="text-muted">(12 rows, 1 bad)</span>
								</a>
							</div>
						</div>

						<!-- File info card (hidden until file selected) -->
						<div id="fileInfoCard" class="file-info-card d-none">
							<div class="d-flex align-items-center gap-2 mb-1">
								<i class="fa-solid fa-file-csv text-accent"></i>
								<span id="fileInfoName" class="fw-semibold text-truncate"></span>
							</div>
							<div class="d-flex gap-3 small text-muted">
								<span><i class="fa-solid fa-weight-hanging me-1"></i><span id="fileInfoSize"></span></span>
								<span><i class="fa-solid fa-list-ol me-1"></i><span id="fileInfoRows"></span> data rows</span>
							</div>
						</div>

						<!-- Actions -->
						<div class="d-flex flex-column gap-2 mt-auto">
							<button id="btnGeocode" class="btn btn-accent w-100" disabled>
								<i class="fa-solid fa-location-dot me-1"></i>Geocode Addresses
							</button>
							<button id="btnClear" class="btn btn-outline-secondary w-100 d-none">
								<i class="fa-solid fa-xmark me-1"></i>Clear
							</button>
						</div>

					</div>
				</div>
			</div>

			<!-- RIGHT PANEL: RESULTS -->
			<div class="col-lg-8">
				<div class="card shadow-sm h-100 position-relative theme-card">
					<div class="card-header theme-card-header d-flex align-items-center gap-2">
						<i class="fa-solid fa-table-list text-accent"></i>
						<strong>Geocoding Results</strong>
					</div>
					<div class="card-body">

						<!-- Spinner overlay -->
						<div id="spinnerOverlay" class="spinner-overlay d-none" aria-label="Processing..." aria-live="polite">
							<div class="spinner-border text-accent" role="status">
								<span class="visually-hidden">Loading...</span>
							</div>
							<p class="mt-2 mb-0 text-muted small">Geocoding addresses…</p>
						</div>

						<!-- API error alert -->
						<div id="apiAlert" class="alert alert-danger alert-dismissible fade d-none" role="alert">
							<i class="fa-solid fa-circle-xmark me-1"></i>
							<span id="apiAlertMsg"></span>
							<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
						</div>

						<!-- Placeholder state -->
						<div id="resultsPlaceholder" class="results-placeholder">
							<i class="fa-solid fa-map-marker-alt fa-3x mb-3 text-muted"></i>
							<p class="text-muted mb-0">Upload a CSV to see geocoding results.</p>
						</div>

						<!-- Results content (hidden until data arrives) -->
						<div id="resultsContent" class="d-none">

							<!-- Summary bar -->
							<div class="summary-bar mb-3">
								<p id="summaryText" class="mb-2 fw-semibold"></p>
								<div class="row g-2 mb-3">
									<div class="col-4">
										<div class="kpi-card text-center">
											<div class="kpi-value" id="kpiTotal">0</div>
											<div class="kpi-label">Total Rows</div>
										</div>
									</div>
									<div class="col-4">
										<div class="kpi-card text-center kpi-success">
											<div class="kpi-value" id="kpiMatched">0</div>
											<div class="kpi-label">Matched</div>
										</div>
									</div>
									<div class="col-4">
										<div class="kpi-card text-center kpi-danger">
											<div class="kpi-value" id="kpiUnmatched">0</div>
											<div class="kpi-label">Unmatched</div>
										</div>
									</div>
								</div>
								<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
									<div class="btn-group" role="group" aria-label="Filter results">
										<button type="button" class="btn btn-sm btn-accent filter-btn active" data-filter="all">All</button>
										<button type="button" class="btn btn-sm btn-outline-accent filter-btn" data-filter="matched">Matched</button>
										<button type="button" class="btn btn-sm btn-outline-accent filter-btn" data-filter="unmatched">Unmatched</button>
									</div>
									<button id="btnExport" class="btn btn-sm btn-outline-accent">
										<i class="fa-solid fa-download me-1"></i>Export CSV
									</button>
								</div>
							</div>

							<!-- Results table -->
							<div class="table-responsive">
								<table id="resultsTable" class="table table-striped table-hover w-100">
									<thead>
										<tr>
											<th>#</th>
											<th>Original Address</th>
											<th>Status</th>
											<th>Matched Address</th>
											<th>Score</th>
											<th>Lat</th>
											<th>Lng</th>
										</tr>
									</thead>
									<tbody></tbody>
								</table>
							</div>

						</div>

					</div>
				</div>
			</div>

		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/BatchGeocoding/app.js"></script>
}
