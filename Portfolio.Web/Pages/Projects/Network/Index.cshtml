@page
@model Portfolio.Web.Pages.Projects.Network.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Route Planner";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />

<div class="spatial-compute-page theme-root">
	<div class="project-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-route me-2"></i>Route Planner</h1>
					<p class="text-muted theme-text-muted mb-0">Compute shortest paths and service areas over a spatial network graph.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-diagram-project me-1"></i>C++ Graph Kernel MVP</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/Network/Details" aria-label="View technical details for Route Planner" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="networkAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-sliders text-accent"></i><strong>Network Controls</strong></div>
					<div class="card-body d-flex flex-column gap-3">
						<div class="row g-2">
							<div class="col-6">
								<label for="networkStart" class="form-label small">Start node</label>
								<select id="networkStart" class="form-select"><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select>
							</div>
							<div class="col-6">
								<label for="networkEnd" class="form-label small">End node</label>
								<select id="networkEnd" class="form-select"><option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option></select>
							</div>
						</div>
						<button id="networkRouteBtn" class="btn btn-accent"><i class="fa-solid fa-location-arrow me-1"></i>Find Route</button>
						<div>
							<label for="networkMaxCost" class="form-label small">Service-area max cost</label>
							<input id="networkMaxCost" class="form-control" type="number" min="1" step="1" value="6" />
						</div>
						<button id="networkServiceAreaBtn" class="btn btn-outline-accent"><i class="fa-solid fa-circle-nodes me-1"></i>Compute Service Area</button>
						<pre id="networkResult" class="sample-json mt-auto mb-0"></pre>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-map-location-dot text-accent"></i><strong>Network Visualization</strong></div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-md-4"><div class="kpi-card text-center"><div id="networkKpiCost" class="kpi-value">0</div><div class="kpi-label">Cost</div></div></div>
							<div class="col-md-4"><div class="kpi-card text-center"><div id="networkKpiNodes" class="kpi-value">0</div><div class="kpi-label">Nodes</div></div></div>
							<div class="col-md-4"><div class="kpi-card text-center"><div id="networkKpiNative" class="kpi-value">No</div><div class="kpi-label">Native</div></div></div>
						</div>
						<div class="spatial-map-panel spatial-stage">
							<svg id="networkSvg" viewBox="0 0 100 100" width="100%" height="420" role="img" aria-label="Spatial graph visualization"></svg>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/Network/app.js" asp-append-version="true"></script>
}
