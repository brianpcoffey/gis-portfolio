@page
@model Portfolio.Web.Pages.Projects.GeoStream.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Live Location Stream";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />

<div class="spatial-compute-page theme-root">
	<div class="spatial-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-satellite-dish me-2"></i>Live Location Stream</h1>
					<p class="text-muted theme-text-muted mb-0">Process live-style GPS telemetry into spatial grid aggregates and anomaly markers.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-microchip me-1"></i>C++ Stream Kernel MVP</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/GeoStream/Details" aria-label="View technical details for Live Location Stream" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="geoStreamAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2">
						<i class="fa-solid fa-sliders text-accent"></i><strong>Telemetry Batch</strong>
					</div>
					<div class="card-body d-flex flex-column gap-3">
						<div>
							<label for="geoGridSize" class="form-label small">Grid size (degrees)</label>
							<input id="geoGridSize" class="form-control" type="number" min="0.001" step="0.001" value="0.01" />
						</div>
						<div>
							<label for="geoAnomalySpeed" class="form-label small">Anomaly speed threshold (m/s)</label>
							<input id="geoAnomalySpeed" class="form-control" type="number" min="0" step="1" value="30" />
						</div>
						<div>
							<label for="geoSampleJson" class="form-label small">Sample events</label>
							<textarea id="geoSampleJson" class="form-control font-monospace" rows="10" aria-label="Sample telemetry JSON"></textarea>
						</div>
						<button id="geoRunBtn" class="btn btn-accent mt-auto">
							<i class="fa-solid fa-play me-1"></i>Process Telemetry
						</button>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2">
						<i class="fa-solid fa-chart-area text-accent"></i><strong>Aggregated Feed View</strong>
					</div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-6 col-md-3"><div class="kpi-card text-center"><div id="geoKpiTotal" class="kpi-value">0</div><div class="kpi-label">Events</div></div></div>
							<div class="col-6 col-md-3"><div class="kpi-card text-center"><div id="geoKpiValid" class="kpi-value">0</div><div class="kpi-label">Valid</div></div></div>
							<div class="col-6 col-md-3"><div class="kpi-card text-center"><div id="geoKpiAnomalies" class="kpi-value">0</div><div class="kpi-label">Anomalies</div></div></div>
							<div class="col-6 col-md-3"><div class="kpi-card text-center"><div id="geoKpiNative" class="kpi-value">No</div><div class="kpi-label">Native</div></div></div>
						</div>
						<div id="geoStage" class="spatial-map-panel spatial-stage mb-3" aria-label="Telemetry aggregate visualization"></div>
						<div id="geoAggregateList" class="result-list"></div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/GeoStream/app.js" asp-append-version="true"></script>
}
