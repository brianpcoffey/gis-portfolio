@page
@model Portfolio.Web.Pages.Projects.Viewshed.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Viewshed Analyzer";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />

<div class="spatial-compute-page theme-root">
	<div class="project-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-eye me-2"></i>Viewshed Analyzer</h1>
					<p class="text-muted theme-text-muted mb-0">Line-of-sight visibility over a terrain grid — click any cell to place the observer and see what they can see, backed by a native C++ ray-casting kernel.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-mountain me-1"></i>C++ Viewshed Kernel</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/Viewshed/Details" aria-label="View technical details for Viewshed Analyzer" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="viewshedAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-sliders text-accent"></i><strong>Observer Controls</strong></div>
					<div class="card-body d-flex flex-column gap-3">
						<div>
							<label for="viewshedSize" class="form-label small">Grid size (cells per side)</label>
							<input id="viewshedSize" class="form-control" type="number" min="8" max="40" value="24" />
						</div>
						<div>
							<label for="viewshedHeight" class="form-label small d-flex justify-content-between">
								<span>Observer height (m)</span><span id="viewshedHeightValue" class="text-accent">2</span>
							</label>
							<input id="viewshedHeight" class="form-range" type="range" min="0" max="60" step="1" value="2" />
						</div>
						<div>
							<label for="viewshedTerrain" class="form-label small">Terrain type</label>
							<select id="viewshedTerrain" class="form-select">
								<option value="ridge" selected>Ridge &amp; valley</option>
								<option value="peak">Central peak</option>
								<option value="rolling">Rolling hills</option>
							</select>
						</div>
						<p class="text-muted theme-text-muted small mb-0"><i class="fa-solid fa-circle-info me-1"></i>Click a cell in the grid to move the observer, then re-run.</p>
						<button id="viewshedRunBtn" class="btn btn-accent"><i class="fa-solid fa-eye me-1"></i>Compute Viewshed</button>
						<button id="viewshedRegenBtn" class="btn btn-outline-accent"><i class="fa-solid fa-arrows-rotate me-1"></i>Regenerate Terrain</button>
						<pre id="viewshedSummary" class="sample-json mt-auto mb-0"></pre>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-table-cells text-accent"></i><strong>Visibility Map</strong></div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-md-3"><div class="kpi-card text-center"><div id="viewshedKpiVisible" class="kpi-value">0</div><div class="kpi-label">Visible</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="viewshedKpiPct" class="kpi-value">0%</div><div class="kpi-label">Coverage</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="viewshedKpiObserver" class="kpi-value">—</div><div class="kpi-label">Observer</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="viewshedKpiNative" class="kpi-value">No</div><div class="kpi-label">Native</div></div></div>
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3">
							<div id="viewshedGrid" class="raster-grid" aria-label="Viewshed visibility grid"></div>
						</div>
						<div class="d-flex flex-wrap gap-3 mt-3 small text-muted theme-text-muted">
							<span><span class="viewshed-swatch viewshed-swatch-visible"></span> Visible terrain</span>
							<span><span class="viewshed-swatch viewshed-swatch-hidden"></span> Hidden terrain</span>
							<span><span class="viewshed-swatch viewshed-swatch-observer"></span> Observer</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/Viewshed/app.js" asp-append-version="true"></script>
}
