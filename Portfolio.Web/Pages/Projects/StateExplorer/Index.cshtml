@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "US State Explorer – Interactive GIS Dashboard";
}

<!-- Custom CSS -->
<link rel="stylesheet" href="~/css/gis.css" />

<!-- Typeahead CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/typeahead.js-bootstrap4-css/1.0.0/typeaheadjs.min.css" />

<div class="container-fluid py-3 theme-root">
    <!-- PAGE TITLE -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="theme-surface shadow-sm rounded p-3">
                <h2 class="mb-1">🗺️ US State Explorer</h2>
                <div class="text-muted theme-text-muted small">
                    Explore, compare, and save U.S. states using interactive GIS tools.
                </div>
            </div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="row mb-3">
        <!-- Align search with left sidebar (matches col sizes used below) -->
        <div class="col-lg-3 col-md-4">
            <div class="theme-toolbar p-3 rounded d-flex align-items-center">
                <div class="input-group flex-nowrap w-100" style="max-width: 100%;">
                    <span class="input-group-text d-flex align-items-center justify-content-center">🔍</span>
                    <input id="searchInput" type="text" class="form-control typeahead" placeholder="Search states..." autocomplete="off">
                </div>
            </div>
        </div>

        <!-- Center toolbar actions -->
        <div class="col-lg-6 col-md-8">
            <div class="theme-toolbar p-3 rounded d-flex flex-wrap gap-2 align-items-center">
                <button id="btnCompareMode" class="btn btn-outline-warning toolbar-btn theme-btn">📊 Compare Mode</button>
                <button id="btnClearSelection" class="btn btn-outline-secondary toolbar-btn theme-btn">✖️ Clear Selection</button>
                <button id="btnExport" class="btn btn-outline-success toolbar-btn theme-btn">📥 Export Data</button>
            </div>
        </div>

        <!-- Right toolbar (basemap select) — aligns with right column on large screens, stacks on smaller -->
        <div class="col-lg-3 col-md-12">
            <div class="theme-toolbar p-3 rounded d-flex align-items-center justify-content-end">
                <select id="basemapSelect" class="form-select form-select-sm" style="min-width: 150px; max-width: 100%;">
                    <option value="streets-navigation-vector">Streets</option>
                    <option value="satellite">Satellite</option>
                    <option value="topo-vector">Topographic</option>
                    <option value="dark-gray-vector">Dark</option>
                </select>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- LEFT SIDEBAR -->
        <div class="col-lg-3 col-md-4">
            <div class="card shadow-sm mb-3 theme-card">
                <div class="card-header d-flex justify-content-between align-items-center theme-card-header">
                    <strong>📁 My Collections</strong>
                    <button id="btnNewCollection" class="btn btn-sm btn-primary theme-btn">+ New</button>
                </div>
                <div class="card-body p-0 theme-body">
                    <div id="collectionsList" class="list-group list-group-flush" style="max-height: 200px; overflow-y:auto;">
                        <div class="list-group-item text-muted text-center small theme-text-muted">Loading...</div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm theme-card">
                <div class="card-header d-flex justify-content-between align-items-center theme-card-header">
                    <strong>💾 Saved States</strong>
                    <span id="savedCount" class="badge bg-primary theme-badge">0</span>
                </div>
                <div class="card-body p-0 theme-body">
                    <div id="savedFeaturesList" class="list-group list-group-flush" style="max-height: 400px; overflow-y:auto;">
                        <div class="list-group-item text-muted text-center small theme-text-muted">No saved states yet</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CENTER - MAP -->
        <div class="col-lg-6 col-md-8">
            <div id="mapView" class="shadow-sm rounded theme-surface" style="height:600px;"></div>

            <div id="comparisonPanel" class="card mt-3 d-none theme-card">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center theme-card-header">
                    <strong>📊 Comparison Results</strong>
                    <button id="btnCloseComparison" class="btn-close"></button>
                </div>
                <div class="card-body comparison-panel theme-panel">
                    <div id="comparisonContent"></div>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDEBAR -->
        <div class="col-lg-3 col-md-12">
            <div class="card shadow-sm mb-3 theme-card">
                <div class="card-header theme-card-header"><strong>📍 State Details</strong></div>
                <div class="card-body theme-body" id="featureDetails">
                    <p class="text-muted text-center small theme-text-muted">Click a state on the map to view details</p>
                </div>
            </div>

            <div class="card shadow-sm theme-card">
                <div class="card-header theme-card-header"><strong>📈 Statistics</strong></div>
                <div class="card-body theme-body">
                    <div id="statsPanel" class="row text-center g-2">
                        <div class="col-6">
                            <div class="border rounded p-3 theme-stat">
                                <div id="statTotal" class="h4 mb-0">0</div>
                                <small class="text-muted theme-text-muted">Total States</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 theme-stat">
                                <div id="statSaved" class="h4 mb-0 text-success">0</div>
                                <small class="text-muted theme-text-muted">Saved</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 theme-stat">
                                <div id="statSelected" class="h4 mb-0 text-primary">0</div>
                                <small class="text-muted theme-text-muted">Selected</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 theme-stat">
                                <div id="statComparing" class="h4 mb-0 text-warning">0</div>
                                <small class="text-muted theme-text-muted">Comparing</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Save Feature Modal -->
<div class="modal fade" id="saveFeatureModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content theme-modal">
            <div class="modal-header theme-modal-header">
                <h5 class="modal-title">Save State</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body theme-body">
                <input type="hidden" id="modalFeatureId" />
                <div class="mb-3">
                    <label class="form-label">State Name</label>
                    <input type="text" id="modalFeatureName" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description / Notes</label>
                    <textarea id="modalDescription" class="form-control" rows="3" placeholder="Add notes about this state..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Add to Collection</label>
                    <select id="modalCollection" class="form-select">
                        <option value="">-- None --</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer theme-modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnConfirmSave" class="btn btn-primary theme-btn">Save State</button>
            </div>
        </div>
    </div>
</div>

<!-- View Saved State Modal -->
<div class="modal fade" id="viewSavedModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content theme-modal">
            <div class="modal-header theme-modal-header">
                <h5 class="modal-title" id="viewSavedTitle">Saved State</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body theme-body">
                <div id="viewSavedMeta" class="mb-2 text-muted small theme-text-muted"></div>
            </div>
            <div class="modal-footer theme-modal-footer">
                <button type="button" id="btnViewZoom" class="btn btn-outline-secondary theme-btn">Zoom</button>
                <button type="button" id="btnViewRemove" class="btn btn-outline-danger theme-btn">Remove</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toast" class="toast theme-toast" role="alert">
        <div class="toast-header theme-toast-header">
            <strong id="toastTitle" class="me-auto">Notification</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div id="toastMessage" class="toast-body theme-toast-body"></div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/typeahead.js/0.11.1/typeahead.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://js.arcgis.com/4.28/"></script>
    <script type="module" src="~/js/StateExplorer/stateStore.js"></script>
    <script type="module" src="~/js/StateExplorer/featureService.js"></script>
    <script type="module" src="~/js/StateExplorer/mapManager.js"></script>
    <script type="module" src="~/js/StateExplorer/uiManager.js"></script>
    <script type="module" src="~/js/StateExplorer/app.js"></script>
}