@page
@model Portfolio.Web.Pages.Projects.Change.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Raster Change Detection";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />

<div class="spatial-compute-page theme-root">
	<div class="project-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-satellite me-2"></i>Raster Change Detection</h1>
					<p class="text-muted theme-text-muted mb-0">Two co-registered satellite passes over the same ground, weeks apart &mdash; what changed? Change Vector Analysis, an automatic Otsu threshold, morphological speckle removal, and connected-component extraction, backed by a native C++ kernel.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-layer-group me-1"></i>C++ Change Kernel</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/Change/Details" aria-label="View technical details for Raster Change Detection" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="changeAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-sliders text-accent"></i><strong>Detection Controls</strong></div>
					<div class="card-body d-flex flex-column gap-3">
						<div>
							<label for="changeSize" class="form-label small">Scene size</label>
							<select id="changeSize" class="form-select">
								<option value="128">128 &times; 128</option>
								<option value="256" selected>256 &times; 256</option>
								<option value="512">512 &times; 512</option>
							</select>
						</div>
						<div>
							<label for="changeNoise" class="form-label small">
								Sensor noise &sigma; <span id="changeNoiseValue" class="text-accent fw-semibold">0.025</span>
							</label>
							<input id="changeNoise" class="form-range" type="range" min="0" max="0.1" step="0.005" value="0.025" />
						</div>
						<div>
							<div class="form-label small mb-1">Threshold mode</div>
							<div class="form-check">
								<input class="form-check-input" type="radio" name="changeThresholdMode" id="changeModeOtsu" value="otsu" checked />
								<label class="form-check-label small" for="changeModeOtsu">Otsu (automatic)</label>
							</div>
							<div class="form-check">
								<input class="form-check-input" type="radio" name="changeThresholdMode" id="changeModeManual" value="manual" />
								<label class="form-check-label small" for="changeModeManual">Manual</label>
							</div>
						</div>
						<div>
							<label for="changeManual" class="form-label small">
								Manual threshold <span id="changeManualValue" class="text-accent fw-semibold">0.20</span>
							</label>
							<input id="changeManual" class="form-range" type="range" min="0" max="1" step="0.005" value="0.2" disabled />
						</div>
						<div>
							<label for="changeOpen" class="form-label small">Open iterations</label>
							<input id="changeOpen" class="form-control" type="number" min="0" max="5" step="1" value="1" />
						</div>
						<div>
							<label for="changeMinArea" class="form-label small">Minimum blob area (px)</label>
							<input id="changeMinArea" class="form-control" type="number" min="0" max="5000" step="1" value="12" />
						</div>
						<button id="changeRunBtn" class="btn btn-accent"><i class="fa-solid fa-play me-1"></i>Detect Changes</button>
						<button id="changeSceneBtn" class="btn btn-outline-accent"><i class="fa-solid fa-arrows-rotate me-1"></i>New Scene</button>
						<div>
							<div class="small text-muted theme-text-muted mb-2">Detections &mdash; click a row to highlight it on the mask</div>
							<div id="changeBlobList" class="result-list"></div>
						</div>
						<pre id="changeSummary" class="sample-json mt-auto mb-0"></pre>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-satellite-dish text-accent"></i><strong>Multitemporal Stack</strong></div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-md-3"><div class="kpi-card text-center"><div id="changeKpiDetections" class="kpi-value">&ndash;</div><div class="kpi-label">Detections</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="changeKpiArea" class="kpi-value">&ndash;</div><div class="kpi-label">Changed Area</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="changeKpiThreshold" class="kpi-value">&ndash;</div><div class="kpi-label">Threshold</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="changeKpiRecovered" class="kpi-value">&ndash;</div><div class="kpi-label">Ground Truth Recovered</div></div></div>
						</div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-left-right me-1"></i>Before / after swipe &mdash; drag the divider or use the slider below. False-colour composite (NIR, Red, Green): healthy vegetation reads red.
						</div>
						<div class="spatial-map-panel d-flex flex-column align-items-center justify-content-center p-3 mb-4">
							<div id="changeSwipeStage" style="position: relative; width: 100%; max-width: 480px; aspect-ratio: 1; cursor: ew-resize; touch-action: none;">
								<canvas id="changeCanvasA" role="img" style="position: absolute; inset: 0; width: 100%; height: 100%; image-rendering: pixelated;" aria-label="Epoch A false-colour composite"></canvas>
								<canvas id="changeCanvasB" role="img" style="position: absolute; inset: 0; width: 100%; height: 100%; image-rendering: pixelated;" aria-label="Epoch B false-colour composite"></canvas>
								<div id="changeSwipeHandle" style="position: absolute; top: 0; bottom: 0; left: 50%; width: 2px; background: var(--accent); pointer-events: none;"></div>
							</div>
							@* Dragging the divider is a pointer-only gesture, so the same
							   position is exposed as a native range input — the keyboard and
							   assistive-tech path to a control that otherwise had none. *@
							<label class="form-label small mt-3 mb-1" for="changeSwipeRange">Divider position</label>
							<input type="range" class="form-range" id="changeSwipeRange"
								   min="0" max="100" step="1" value="50"
								   style="max-width: 480px;" />
						</div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-object-group me-1"></i>Change mask over epoch B &mdash; solid boxes are detections, dashed boxes are planted ground truth.
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3 mb-4">
							<canvas id="changeMaskCanvas" role="img" style="width: 100%; max-width: 480px; aspect-ratio: 1; image-rendering: pixelated;" aria-label="Detected change mask with detection and ground-truth bounding boxes"></canvas>
						</div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-chart-simple me-1"></i>CVA magnitude histogram &mdash; the vertical line is the chosen threshold. Raise the noise and watch it move.
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3">
							<svg id="changeHistogramSvg" role="img" viewBox="0 0 100 56" preserveAspectRatio="xMidYMid meet" class="w-100" style="max-width: 620px;" aria-label="Change vector analysis magnitude histogram with the Otsu threshold marked"></svg>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="~/js/Change/app.js" asp-append-version="true"></script>
}
