@page
@model Portfolio.Web.Pages.Projects.Fleet.IndexModel
@{
	Layout = "/Pages/Shared/_Layout.cshtml";
	ViewData["Title"] = "Fleet Route Optimizer";
}

<link rel="stylesheet" href="~/css/gis.css" />
<link rel="stylesheet" href="~/css/spatialcompute.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.css"
	  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<div class="spatial-compute-page theme-root">
	<div class="project-hero py-4 mb-4">
		<div class="container">
			<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
				<div>
					<h1 class="mb-1"><i class="fa-solid fa-truck-fast me-2"></i>Fleet Route Optimizer</h1>
					<p class="text-muted theme-text-muted mb-0">Capacitated vehicle routing with time windows over the real Redlands street network — Clarke-Wright savings construction followed by 2-opt and Or-opt local search, in a native C++ kernel.</p>
				</div>
				<div class="d-flex align-items-center gap-2">
					<span class="badge badge-gis fs-6"><i class="fa-solid fa-diagram-project me-1"></i>C++ VRP Solver</span>
					<a class="btn btn-outline-accent btn-sm project-info-btn" href="/Projects/Fleet/Details" aria-label="View technical details for Fleet Route Optimizer" title="Technical Details">
						<i class="fa-solid fa-circle-info"></i>
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="container pb-5">
		<div id="fleetAlert" class="alert alert-danger d-none" role="alert"></div>
		<div class="row g-4">
			<div class="col-lg-4">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-sliders text-accent"></i><strong>Fleet Controls</strong></div>
					<div class="card-body d-flex flex-column gap-3">
						<div>
							<label for="fleetPreset" class="form-label small">Scenario</label>
							<select id="fleetPreset" class="form-select">
								<option value="morning">Morning parcel run — 25 stops</option>
								<option value="fullday" selected>Full day route — 40 stops</option>
								<option value="tight">Tight windows — 40 stops</option>
							</select>
							<div id="fleetPresetHint" class="form-text theme-text-muted"></div>
						</div>
						<div class="row g-2">
							<div class="col-6">
								<label for="fleetVehicles" class="form-label small">Vehicles</label>
								<input id="fleetVehicles" class="form-control" type="number" min="1" max="10" step="1" value="5" />
							</div>
							<div class="col-6">
								<label for="fleetCapacity" class="form-label small">Capacity (kg)</label>
								<input id="fleetCapacity" class="form-control" type="number" min="100" max="5000" step="50" value="1200" />
							</div>
						</div>
						<div>
							<label for="fleetFixedCost" class="form-label small">Vehicle fixed cost (km equivalent)</label>
							<input id="fleetFixedCost" class="form-control" type="number" min="0" max="500" step="5" value="25" />
						</div>
						<div>
							<label for="fleetIterations" class="form-label small">
								Max local-search passes <span id="fleetIterationsValue" class="text-accent fw-semibold">1000</span>
							</label>
							<input id="fleetIterations" class="form-range" type="range" min="100" max="5000" step="100" value="1000" />
						</div>
						<button id="fleetOptimizeBtn" class="btn btn-accent"><i class="fa-solid fa-play me-1"></i>Optimize</button>
						<button id="fleetResetBtn" class="btn btn-outline-accent"><i class="fa-solid fa-arrows-rotate me-1"></i>Reset Scenario</button>
						<div>
							<div class="small text-muted theme-text-muted mb-2">Routes</div>
							<div id="fleetRouteList" class="result-list" aria-live="polite"></div>
						</div>
						<pre id="fleetSummary" class="sample-json mt-auto mb-0"></pre>
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card spatial-card shadow-sm h-100">
					<div class="card-header d-flex align-items-center gap-2"><i class="fa-solid fa-map-location-dot text-accent"></i><strong>Dispatch Plan</strong></div>
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-md-3"><div class="kpi-card text-center"><div id="fleetKpiVehicles" class="kpi-value">&ndash;</div><div class="kpi-label">Vehicles Used</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="fleetKpiDistance" class="kpi-value">&ndash;</div><div class="kpi-label">Total Distance</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="fleetKpiLongest" class="kpi-value">&ndash;</div><div class="kpi-label">Longest Route</div></div></div>
							<div class="col-md-3"><div class="kpi-card text-center"><div id="fleetKpiImprovement" class="kpi-value">&ndash;</div><div class="kpi-label">Improvement</div></div></div>
						</div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-location-dot me-1"></i>Routes follow real streets. The depot is the square marker; stops are numbered in visit order and coloured by vehicle. Unserved stops are grey.
						</div>
						<div id="fleetMap" class="spatial-map-panel mb-4" style="min-height: 460px;" role="application" aria-label="Fleet route map"></div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-chart-line me-1"></i>Convergence &mdash; objective (distance plus a fixed cost per vehicle) after construction and after each local-search pass.
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3 mb-4">
							<svg id="fleetConvergenceSvg" role="img" viewBox="0 0 100 46" preserveAspectRatio="xMidYMid meet" class="w-100" style="max-width: 620px;" aria-label="Objective convergence chart"></svg>
						</div>

						<div class="mb-2 small text-muted theme-text-muted">
							<i class="fa-solid fa-bars-staggered me-1"></i>Schedule &mdash; one bar per vehicle across the shift. The light band behind each block is the customer's time window; the block is the actual arrival and service.
						</div>
						<div class="spatial-map-panel d-flex align-items-center justify-content-center p-3">
							<svg id="fleetScheduleSvg" role="img" viewBox="0 0 100 60" preserveAspectRatio="xMidYMid meet" class="w-100" style="max-width: 660px;" aria-label="Vehicle schedule timeline"></svg>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="https://unpkg.com/leaflet@@1.9.4/dist/leaflet.js"
		integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
	<script src="~/js/Fleet/app.js" asp-append-version="true"></script>
}
