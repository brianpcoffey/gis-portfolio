# Copy this file to .env and fill in values for local development
# Never commit .env to source control

# PostgreSQL (Neon.tech or local)
DATABASE_URL=postgres://user:password@host:5432/portfolio

# Redis (Upstash or local)
# Leave empty to use in-memory fallback
# Supports both formats:
#   - StackExchange.Redis: host:6379,password=...,ssl=True,abortConnect=False
#   - URI format: rediss://default:password@host:6379
Redis__ConnectionString=

# Google OAuth
Authentication__Google__ClientId=your-client-id
Authentication__Google__ClientSecret=your-client-secret

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
